---
interface Props {
  lang?: 'he' | 'en';
  donateUrl?: string;
}

const { lang = 'he', donateUrl = '#' } = Astro.props;
const isHebrew = lang === 'he';

const navItems = isHebrew
  ? [
      { href: '#challenge', label: 'האתגר' },
      { href: '#story', label: 'הסיפור' },
      { href: '#protocol', label: 'הפרוטוקול' },
      { href: '#community', label: 'הקהילה' },
      { href: '#impact', label: 'השפעה' },
      { href: '#contact', label: 'צרו קשר' },
    ]
  : [
      { href: '#about', label: 'About' },
      { href: '#impact', label: 'Impact' },
      { href: '#contact', label: 'Contact' },
    ];

const langToggle = isHebrew
  ? { href: '/en/', label: 'EN' }
  : { href: '/', label: 'עב' };

const donateLabel = isHebrew ? 'תרמו' : 'Donate';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-transparent transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href={isHebrew ? '/' : '/en/'} class="flex items-center gap-2">
        <span class="text-xl sm:text-2xl font-bold text-earth-900 font-heebo">
          חוות קשת
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-earth-700 hover:text-terracotta transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-3 sm:gap-4">
        <a
          href={langToggle.href}
          class="text-sm font-medium text-earth-700 hover:text-earth-900 transition-colors border border-earth-300 rounded-full px-3 py-1"
        >
          {langToggle.label}
        </a>
        <a
          href={donateUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-terracotta text-white text-sm font-semibold px-4 sm:px-6 py-2 rounded-full hover:bg-terracotta/90 transition-colors"
        >
          {donateLabel}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col gap-1.5 p-2"
          aria-label="Toggle menu"
        >
          <span class="w-5 h-0.5 bg-earth-900"></span>
          <span class="w-5 h-0.5 bg-earth-900"></span>
          <span class="w-5 h-0.5 bg-earth-900"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <nav
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-earth-100"
    >
      <div class="flex flex-col gap-2 pt-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-base font-medium text-earth-700 hover:text-terracotta transition-colors py-2"
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>
