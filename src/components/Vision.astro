---
---

<section id="vision" class="relative py-16 sm:py-24 bg-sand grain">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="fade-in text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-earth-900 mb-4 font-heebo">
        למה עכשיו?
      </h2>
      <p class="text-lg sm:text-xl text-earth-700 max-w-3xl mx-auto leading-relaxed">
        מדינת ישראל נמצאת בנקודת שפל היסטורית של פגיעות נפשית. מאות אלפי אנשים זקוקים למענה שאינו רק תרופתי, אלא קהילתי וחווייתי.
      </p>
    </div>

    <!-- Three tiers -->
    <div class="flex flex-col items-center gap-8">
      <!-- Tier 1 -->
      <div class="fade-in w-full max-w-md">
        <div class="bg-earth-100 rounded-2xl p-6 sm:p-8 text-center shadow-sm border-2 border-terracotta/20">
          <div class="w-20 h-20 bg-terracotta/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-black text-terracotta">1</span>
          </div>
          <h3 class="text-xl font-bold text-earth-900 mb-2 font-heebo">חוות קשת</h3>
          <p class="text-earth-700">
            96 משתתפי דיור מוגן בשנה — 21 ימי שיקום<br />
            6,750 משתתפי סדנאות וטיפולים
          </p>
        </div>
      </div>

      <!-- Arrow -->
      <div class="fade-in text-earth-300">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>

      <!-- Tier 2 -->
      <div class="fade-in w-full max-w-lg">
        <div class="bg-earth-100 rounded-2xl p-6 sm:p-8 text-center shadow-sm border-2 border-earth-500/20">
          <div class="w-20 h-20 bg-earth-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl font-black text-earth-500">10</span>
          </div>
          <h3 class="text-xl font-bold text-earth-900 mb-2 font-heebo">10 חוות קשת</h3>
          <p class="text-earth-700">
            960 משתתפי דיור מוגן בשנה<br />
            67,500 משתתפי סדנאות וטיפולים
          </p>
        </div>
      </div>

      <!-- Arrow -->
      <div class="fade-in text-earth-300">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>

      <!-- Tier 3 -->
      <div class="fade-in w-full max-w-xl">
        <div class="bg-earth-100 rounded-2xl p-6 sm:p-8 text-center shadow-sm border-2 border-sage-600/20">
          <div class="w-20 h-20 bg-sage-600/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-earth-900 mb-2 font-heebo">קרן קשת</h3>
          <p class="text-earth-700">
            רשת של חוות תמיכה וריפוי ברחבי הארץ ובעולם — רשת סולידריות שמנגישה לאנשים שמתמודדים עם פוסט טראומה את היכולת לרכוש אדמות ולנהל חוות מרפאות.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
