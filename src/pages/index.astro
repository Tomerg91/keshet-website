---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Challenge from '../components/Challenge.astro';
import Story from '../components/Story.astro';
import Protocol from '../components/Protocol.astro';
import Community from '../components/Community.astro';
import Impact from '../components/Impact.astro';
import Vision from '../components/Vision.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const donateUrl = '#'; // Replace with external donation platform URL
---

<Layout
  title="חוות קשת — שיקום פוסט-טראומה דרך נשימה, קהילה וטבע"
  description="חוות קשת היא מרכז שיקומי-קהילתי לנפגעי פוסט-טראומה (PTSD) בישראל. פרוטוקול ייחודי המשלב נשימה תרפויטית, טכנולוגיית HeartMath, טבע ובעלי חיים. 90% מהמשתתפים מדווחים על שיפור תוך חודש."
  lang="he"
  dir="rtl"
>
  <Header lang="he" donateUrl={donateUrl} />
  <main>
    <Hero lang="he" />
    <Challenge />
    <Story />
    <Protocol />
    <Community />
    <Impact lang="he" />
    <Vision />
    <FAQ lang="he" />
    <ContactForm lang="he" />
  </main>
  <Footer lang="he" donateUrl={donateUrl} />
</Layout>
