---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Challenge from '../components/Challenge.astro';
import Story from '../components/Story.astro';
import Protocol from '../components/Protocol.astro';
import Community from '../components/Community.astro';
import Impact from '../components/Impact.astro';
import Vision from '../components/Vision.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const donateUrl = '#'; // Replace with external donation platform URL
---

<Layout title="חוות קשת — מחזירים את הריבונות לנפש" lang="he" dir="rtl">
  <Header lang="he" donateUrl={donateUrl} />
  <main>
    <Hero lang="he" />
    <Challenge />
    <Story />
    <Protocol />
    <Community />
    <Impact lang="he" />
    <Vision />
    <ContactForm lang="he" />
  </main>
  <Footer lang="he" donateUrl={donateUrl} />
</Layout>
